<%# Fabric-X Environment Variables %>
<%# Generated by Fablo — Fabric-X Engine %>

# ===================================================
# Fabric-X Docker Image Configuration
# ===================================================

# Fabric-X component images (prebuilt from GHCR)
FABRIC_X_ORDERER_IMAGE=ghcr.io/hyperledger/fabric-x-orderer:<%= global.fabricX.version %>
FABRIC_X_COMMITTER_IMAGE=ghcr.io/hyperledger/fabric-x-committer:<%= global.fabricX.version %>
FABRIC_X_TOOLS_IMAGE=ghcr.io/hyperledger/fabric-x-tools:<%= global.fabricX.version %>
FABRIC_X_LOADGEN_IMAGE=ghcr.io/hyperledger/fabric-x-loadgen:<%= global.fabricX.version %>

# Classic Fabric images (for CA, tools compatibility)
FABRIC_CA_IMAGE=<%= global.caImage %>

# Fabric-X version
FABRIC_X_VERSION=<%= global.fabricX.version %>

# ===================================================
# General Configuration
# ===================================================
COMPOSE_PROJECT_NAME=fablo-fabric-x
LOGGING_LEVEL=<%= global.monitoring.loglevel %>

# CA Admin credentials
<% orgs.forEach(function(org){ %>
<%= org.ca.caAdminNameVar %>=admin
<%= org.ca.caAdminPassVar %>=adminpw
<% }) %>
