    "channel": "my-channel1",
    "dockerNetwork": "fablo_network_202404081234",
    "tls": true,
    "ca": {
      "url": "https://ca.orderer.example.com:7054",
      "tlsCACertPath": "fabric-config/external-network-ca-cert.pem"
    }
