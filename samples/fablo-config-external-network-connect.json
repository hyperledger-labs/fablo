{
  "$schema": "https://github.com/hyperledger-labs/fablo/releases/download/2.5.0/schema.json",
  "global": {
    "fabricVersion": "2.5.9",
    "tls": true,
    "peerDevMode": false
  },
  "orgs": [
    {
      "organization": {
        "name": "Org2",
        "domain": "org2.example.com",
        "mspName": "Org2MSP"
      },
      "ca": {
        "prefix": "ca",
        "db": "sqlite"
      },
      "orderers": [],
